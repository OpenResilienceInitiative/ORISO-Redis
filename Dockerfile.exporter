FROM oliver006/redis_exporter:latest

# Expose Redis Exporter metrics port
EXPOSE 9121

# Health check
HEALTHCHECK --interval=10s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:9121/metrics || exit 1

# Use the default entrypoint from base image
# Environment variables are set via Kubernetes deployment:
# - REDIS_ADDR: Redis server address (e.g., redis:6379)
# - REDIS_PASSWORD: Redis password

