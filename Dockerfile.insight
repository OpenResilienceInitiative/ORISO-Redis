FROM redis/redisinsight:latest

# Expose RedisInsight port
EXPOSE 8001

# Health check
HEALTHCHECK --interval=15s --timeout=3s --start-period=30s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8001/ || exit 1

# Use the default entrypoint from base image
# RedisInsight is a desktop application that can also run in server mode
# Environment variables can be set via Kubernetes deployment if needed

